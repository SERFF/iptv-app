<?xml version="1.0" encoding="utf-8"?>
<!-- Many IPTV providers still serve over plain HTTP; Android 9+ blocks that by default. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
